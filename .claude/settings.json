{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "git add -A && git diff --cached --quiet || (git commit -m 'auto: save changes' && git push)",
            "statusMessage": "Pushing to GitHub..."
          }
        ]
      }
    ]
  }
}
